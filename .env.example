# ─────────────────────────────────────────────────────────────────────────────
# Sentinel – API Keys & Configuration
# Copy this file to .env and fill in your credentials
# ─────────────────────────────────────────────────────────────────────────────

# NASA FIRMS – Fire Information for Resource Management System
# Free API key at: https://firms.modaps.eosdis.nasa.gov/api/
# Used for: Real-time fire hotspots (VIIRS + MODIS)
VITE_NASA_FIRMS_API_KEY=your_firms_map_key_here

# AirNow API – EPA Air Quality Data
# Free API key at: https://docs.airnowapi.org/login
# Used for: Real-time AQI monitoring stations
VITE_AIRNOW_API_KEY=your_airnow_api_key_here

# Mapbox (Optional – only if you want higher-quality base tiles)
# Free token at: https://account.mapbox.com/
# Leave empty to use the default free MapLibre + Carto dark tiles
VITE_MAPBOX_TOKEN=pk.eyJ1Ijoia2Jlc2hvcmU2IiwiYSI6ImNtaG1kN3NvMjA5eTEyaW9nNG9uMjdqcWUifQ.JywdBqHqT3tcQ8IbyljLjg


# Supabase – Reporter submission system backend
# Create a free project at: https://supabase.com/
# Copy the URL + anon key from Project Settings → API
# Then run supabase/schema.sql in the Supabase SQL editor.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App settings
# How often to refresh live data (milliseconds). Default: 5 minutes
VITE_REFRESH_INTERVAL=300000

# NIFC / WFIGS perimeters – No key required (public ArcGIS endpoint)
# NOAA Weather Alerts – No key required (public US government API)
# US Drought Monitor – No key required (public endpoint)
