# GOES satellite tile endpoints (optional)
# Defaults use Iowa Environmental Mesonet WMS. Set these only if you run your own
# NOAA GOES tile service (for example, a GOES-DL-backed pipeline).
# Each value must be a raster URL template compatible with mapbox-gl:
#  - XYZ template: https://example.com/tiles/{z}/{x}/{y}.png
#  - WMS template: ...&BBOX={bbox-epsg-3857}
# VITE_GOES_EAST_VISIBLE_TILE_URL=
# VITE_GOES_WEST_VISIBLE_TILE_URL=
# VITE_GOES_EAST_FIRE_RGB_TILE_URL=
# VITE_GOES_WEST_FIRE_RGB_TILE_URL=
# Optional attribution overrides when using custom tile sources:
# VITE_GOES_EAST_ATTRIBUTION=
# VITE_GOES_WEST_ATTRIBUTION=
# VITE_GOES_EAST_FIRE_ATTRIBUTION=
# VITE_GOES_WEST_FIRE_ATTRIBUTION=

# App settings
# How often to refresh live data (milliseconds). Default: 5 minutes
VITE_REFRESH_INTERVAL=300000

# IPAWS OPEN EAS JSON (optional). In local dev, defaults to `/alerts` when unset (Vite proxies to `npm run ipaws-server`).
# In production, set to your deployed poller URL, e.g. https://api.example.com/alerts
# VITE_IPAWS_ALERTS_URL=

# ── Secrets stored in Supabase (NOT in this file) ──────────────────────────────
# Sensitive API keys are stored as Supabase project secrets and consumed only
# inside the server-side edge functions in supabase/functions/.
# Run the following commands once after creating your Supabase project:
#
#   supabase secrets set NASA_FIRMS_API_KEY=<your_key>
#   supabase secrets set AIRNOW_API_KEY=<your_key>
#   supabase secrets set MAPBOX_TOKEN=<your_token>
#
# Get keys at:
#   NASA FIRMS : https://firms.modaps.eosdis.nasa.gov/api/
#   AirNow     : https://docs.airnowapi.org/login
#   Mapbox     : https://account.mapbox.com/

# NIFC / WFIGS perimeters – No key required (public ArcGIS endpoint)
